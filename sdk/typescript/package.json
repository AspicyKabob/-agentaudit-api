{
  "name": "agentaudit-client",
  "version": "1.0.4",
  "description": "Audit \u0026 Compliance SDK for AI Agents (TypeScript)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js",
      "require": "./dist/langchain.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": [
    "ai",
    "agents",
    "audit",
    "compliance",
    "monitoring",
    "langchain",
    "typescript"
  ],
  "author": "AgentAudit Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@langchain/core": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  }
}
