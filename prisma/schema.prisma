generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  plan          String   @default("free")
  apiQuota      Int      @default(5000)
  apiUsed       Int      @default(0)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  webhookUrl          String?
  notifyWebhook       Boolean  @default(true)
  notifyEmail         Boolean  @default(true)
  notifyMinSeverity   String   @default("warning")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  apiKeys       ApiKey[]
  agents        Agent[]
  auditLogs     AuditLog[]
  policies      Policy[]
  complianceRules ComplianceRule[]
  reports       ComplianceReport[]
  alerts        Alert[]
}

model ApiKey {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  keyHash       String   @unique
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  revokedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Agent {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  type          String
  description   String?
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs     AuditLog[]
  agentPolicies AgentPolicy[]
}

model AuditLog {
  id            String   @id @default(uuid())
  organizationId String
  agentId       String?
  action        String
  prompt        String?
  response      String?
  metadata      Json?
  complianceFlags String[]
  traceId       String?
  parentSpanId  String?
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([organizationId, traceId])
  @@index([organizationId, parentSpanId])
  @@index([organizationId, createdAt])
}

model Policy {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  description   String?
  isActive      Boolean  @default(true)
  sourcePackId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rules        ComplianceRule[]
  agentPolicies AgentPolicy[]

  @@index([organizationId, isActive])
}

model AgentPolicy {
  id        String   @id @default(uuid())
  agentId   String
  policyId  String
  createdAt DateTime @default(now())

  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  policy    Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([agentId, policyId])
  @@index([agentId])
  @@index([policyId])
}

model ComplianceRule {
  id            String   @id @default(uuid())
  organizationId String
  policyId      String?
  name          String
  ruleType      String
  condition     Json
  severity      String   @default("warning")
  isActive      Boolean  @default(true)
  packId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policy       Policy?      @relation(fields: [policyId], references: [id], onDelete: Cascade)
  alerts       Alert[]

  @@index([organizationId, policyId])
}

model ComplianceReport {
  id            String   @id @default(uuid())
  organizationId String
  name          String
  format        String
  dateRangeStart DateTime
  dateRangeEnd  DateTime
  status        String   @default("pending")
  downloadUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Alert {
  id            String   @id @default(uuid())
  organizationId String
  ruleId        String?
  auditLogId    String?
  severity      String
  message       String
  details       Json?
  isResolved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rule         ComplianceRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String
  window    DateTime
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, window])
  @@index([key])
  @@index([window])
}
