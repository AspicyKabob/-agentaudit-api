# AgentAudit API — Environment Variables
# THIS IS A TEMPLATE. Copy to .env and fill in real values.
# NEVER commit .env (it is already in .gitignore).
# NEVER put real production secrets in this file.

# ============================================
# REQUIRED — Application Core
# ============================================

NODE_ENV=production
PORT=8080

# PostgreSQL connection string.
# Self-hosted Docker: postgresql://postgres:postgres@db:5432/agentaudit?schema=public
# Self-hosted bare metal: postgresql://user:password@localhost:5432/agentaudit?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentaudit?schema=public"

# JWT secret for signing authentication tokens.
# Generate a secure value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_64_CHARACTER_HEX_STRING"

# Salt for hashing API keys.
# Generate a secure value:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
API_KEY_SALT="CHANGE_THIS_TO_32_CHARACTER_HEX_STRING"

# ============================================
# OPTIONAL — Authentication
# ============================================

# JWT access token expiration (default: 15m)
JWT_ACCESS_EXPIRATION=15m

# JWT refresh token expiration (default: 7d)
JWT_REFRESH_EXPIRATION=7d

# ============================================
# OPTIONAL — Frontend URL
# ============================================
# Used for Stripe checkout redirects and email links.
# FRONTEND_URL="https://agentaudit-api-production.up.railway.app"

# ============================================
# OPTIONAL — Email (Resend)
# ============================================
# Leave empty to disable transactional email (welcome emails, alert emails).
# Sign up at https://resend.com, verify your domain, and generate an API key.

# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="AgentAudit <noreply@agentaudit.io>"

# ============================================
# OPTIONAL — Billing (Stripe)
# ============================================
# Leave ALL Stripe variables empty to disable billing.
# When disabled, every organization is treated as the "free" plan.
# If you enable billing, ALL Stripe variables below must be set.

# Stripe secret key — get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."

# Stripe publishable key — used by the frontend / website
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook endpoint secret — create a webhook endpoint pointing to /api/v1/billing/webhook
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs for subscription tiers. Create products + prices in Stripe Dashboard first.
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_BUSINESS="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."

# ============================================
# OPTIONAL — Redis (Rate Limiting)
# ============================================
# Redis enables distributed rate limiting across multiple containers.
# When omitted, rate limiting falls back to the Prisma PostgreSQL store.
# Recommended for production; safe to skip for local development.

# REDIS_URL="redis://localhost:6379"
# REDIS_ENABLED="true"

# ============================================
# OPTIONAL — Observability
# ============================================

# Sentry DSN for error tracking
# SENTRY_DSN="https://..."

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ============================================
# OPTIONAL — Rate Limiting
# ============================================
# Built-in IP-based rate limiting. Disabled if not set.

# Max requests per IP per window (default: 100)
# RATE_LIMIT_MAX=100

# Window size in milliseconds (default: 15 minutes = 900000)
# RATE_LIMIT_WINDOW_MS=900000

# ============================================
# SELF-HOSTING QUICK START
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in REQUIRED variables (DATABASE_URL, JWT_SECRET, API_KEY_SALT)
# 3. If you don't need billing, leave Stripe variables empty.
# 4. Run: npm install && npx prisma migrate deploy && npm run build
# 5. Start: npm start
# 6. Verify: curl http://localhost:8080/health
# See docs/self-hosting.md for full Docker and bare-metal guides.
