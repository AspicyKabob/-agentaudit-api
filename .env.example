# AgentAudit API — Environment Variables
# Copy this file to .env and fill in real values

NODE_ENV=production
PORT=8080

# ─── Database ───────────────────────────────────────────────────────
# Railway/Render auto-inject this. For local dev:
DATABASE_URL="postgresql://user:password@localhost:5432/agentaudit?schema=public"

# ─── JWT Secrets ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_64_CHAR_HEX_STRING"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── API Key Salt ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
API_KEY_SALT="CHANGE_THIS_RANDOM_SALT"

# ─── Stripe (Required for billing) ─────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Create products + prices in Stripe Dashboard, then paste IDs here
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
