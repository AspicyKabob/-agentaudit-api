{
  "name": "agentaudit-api",
  "version": "1.1.0-trace",
  "description": "Agent Audit & Compliance API for AI agents",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/copy-website.js",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test:prepare": "node scripts/prepare-test-sdk.js",
    "pretest": "npm run test:prepare",
    "verify": "npm run lint && npm run build && npm test -- --runInBand",
    "verify:ci": "npm run lint && npm run build && npm test -- --runInBand --no-coverage --forceExit"
  },
  "keywords": [
    "api",
    "ai",
    "agents",
    "audit",
    "compliance",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@sentry/node": "10.57.0",
    "@types/sentiment": "^5.0.4",
    "bcryptjs": "^2.4.3",
    "convict": "^6.2.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "prisma": "^5.10.0",
    "rate-limit-redis": "^4.3.1",
    "re2": "^1.24.1",
    "redis": "^4.7.1",
    "resend": "^6.12.4",
    "sentiment": "^5.0.2",
    "stripe": "^22.1.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@langchain/core": "^1.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/convict": "^6.1.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pglite-prisma-adapter": "^0.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
